function drawAnn(){
    if(ann.t>=ann.mx||ann.mx===0)return;
    const p=ann.t/ann.mx;
    let sc=1,al=1;
    if(p<.12){sc=p/.12*1.35;al=p/.12}
    else if(p<.22){sc=1.35-(p-.12)/.1*.35;al=1}
    else if(p>.7)al=1-(p-.7)/.3;

    X.save();X.globalAlpha=al;X.textAlign='center';X.textBaseline='middle';
    X.shadowColor='rgba(255,100,50,.5)';X.shadowBlur=35;
    X.font=`900 ${58*sc}px Orbitron`;X.fillStyle='#f0e6d3';
    X.fillText(ann.text,W/2,H/2-18);
    X.shadowBlur=0;
    if(ann.sub){X.font=`600 ${21*sc}px Rajdhani`;X.fillStyle='#ff6630';X.fillText(ann.sub,W/2,H/2+28)}
    X.restore();
}

